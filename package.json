{
  "name": "github-network-graph",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "Visualize the GitHub network graph (forks + main repo) in a dedicated tab.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build:prod": "cross-env NODE_ENV=production tsc -b && cross-env NODE_ENV=production vite build --mode production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "package": "pnpm build:prod && node scripts/package.mjs",
    "clean": "rimraf dist releases",
    "release": "pnpm version patch && git push --follow-tags"
  },
  "dependencies": {
    "@aptabase/web": "^0.5.0",
    "@tanstack/react-virtual": "^3.14.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "archiver": "^8.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "author": "pr-kzk <pr-kzk@gmail.com>",
  "homepage": "https://github.com/pr-kzk/github-network-graph#readme",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pr-kzk/github-network-graph.git"
  },
  "bugs": {
    "url": "https://github.com/pr-kzk/github-network-graph/issues"
  }
}
